
<nav class="navbar">
  <!-- Left: Logo + Name -->
  <div class="nav-left">
    <span class="brand-name">Navix</span>
  </div>

  <!-- Center: Links -->
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/plan">Plan Route</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact</a></li>
    <li><a href="/history">Past History</a></li>
  </ul>

  <!-- Right: Auth -->
  <div class="nav-right">
    <% if (currentUser) { %>
      <span class="login">Hi, <%= currentUser.name %></span>
      <form method="POST" action="/auth/logout" class="logout-form">
        <button type="submit" class="signup-btn logout-btn">Logout</button>
      </form>
    <% } else { %>
      <a href="/login" class="login">Login</a>
      <a href="/signup" class="signup-btn">Sign Up</a>
    <% } %>
  </div>
</nav>
