<% layout("/layouts/boilerplate.ejs") %>

<section class="result-section">
    <h1 class="result-title">Your Route</h1>

    <div class="query-info" id="queryInfo"></div>
    <div class="data-source-badge" id="dataSourceBadge"></div>

    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-label">Total Distance</span>
            <span class="stat-value" id="totalDistance">--</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Total Time</span>
            <span class="stat-value" id="totalTime">--</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Total Cost</span>
            <span class="stat-value" id="totalCost">--</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Stops</span>
            <span class="stat-value" id="stops">--</span>
        </div>
    </div>

    <div class="route-viz-card">
        <h2 class="route-viz-title">Path Visualization</h2>
        <p class="route-viz-subtitle">From source to destination with each hop highlighted.</p>
        <div class="route-stepper" id="routeStepper"></div>
    </div>

    <div class="legs-grid" id="legsGrid"></div>

    <div class="path-display" id="pathDisplay"></div>

    <div class="other-routes-card">
        <h2 class="route-viz-title">Other Possible Paths</h2>
        <p class="route-viz-subtitle">Optimal path is selected by Dijkstra. Alternatives are shown for comparison.</p>
        <div class="other-routes-list" id="otherRoutesList"></div>
    </div>

    <div class="map-card">
        <h2 class="route-viz-title">Route On Map</h2>
        <p class="route-viz-subtitle">Geographic path rendered with OpenStreetMap.</p>
        <div class="path-legend">
            <span class="legend-item"><span class="legend-line legend-optimal"></span>Optimal path</span>
            <span class="legend-item"><span class="legend-line legend-alt"></span>Other paths</span>
        </div>
        <div id="route-map"></div>
        <p class="map-fallback" id="mapFallback"></p>
    </div>

    <div class="path-legend">
        <span class="legend-item"><span class="legend-line legend-optimal"></span>Optimal graph edges</span>
        <span class="legend-item"><span class="legend-line legend-alt"></span>Other route edges</span>
    </div>
    <div id="graph-container"></div>

    <button class="submit-btn" onclick="window.location.href='/plan'">Plan Another Route</button>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
<script>
    const resultRaw = sessionStorage.getItem('routeResult');
    const queryRaw = sessionStorage.getItem('routeQuery');

    if (!resultRaw || !queryRaw) {
        window.location.href = '/plan';
    }

    const result = JSON.parse(resultRaw);
    const query = JSON.parse(queryRaw);
    const allowedPreferences = ['distance', 'time', 'cost'];
    const normalizedPreference = String(query.preference || '').toLowerCase();
    const activePreference = allowedPreferences.includes(normalizedPreference)
        ? normalizedPreference
        : 'distance';

    document.body.classList.add('result-theme', `result-theme-${activePreference}`);

    const themePalette = {
        distance: { accent: '#38BDF8', highlight: '#00e5a8' },
        time: { accent: '#34D399', highlight: '#6EE7B7' },
        cost: { accent: '#F59E0B', highlight: '#FCD34D' }
    };
    const alternativePalette = ['#fb7185', '#f97316', '#a78bfa', '#22d3ee'];
    const alternativeGraphColor = '#fb923c';
    const palette = themePalette[activePreference];
    document.body.style.setProperty('--legend-optimal', palette.highlight);
    document.body.style.setProperty('--legend-alt', alternativeGraphColor);

    const graphMeta = result.graph || {};
    const allEdgesData = Array.isArray(graphMeta.edges) ? graphMeta.edges : [];
    const allCities = Array.isArray(graphMeta.cities) ? graphMeta.cities : [];

    const path = Array.isArray(result.path) ? result.path : [];
    const totalDistance = result.totalDistance ?? 0;
    const totalTime = result.totalTime ?? 0;
    const totalCost = result.totalCost ?? 0;
    const stops = Number.isFinite(result.stops) ? result.stops : Math.max(path.length - 1, 0);

    if (!path.length) {
        window.location.href = '/noroute';
    }

    const edgeMap = new Map();
    const edgeKey = (a, b) => [a, b].sort().join('|');
    const mapGeocodeCache = new Map();

    allEdgesData.forEach(edge => {
        edgeMap.set(edgeKey(edge.from, edge.to), edge);
    });

    const getLeg = (from, to) => edgeMap.get(edgeKey(from, to));
    const sourceCity = query.source || path[0];
    const destinationCity = query.destination || path[path.length - 1];

    function buildAdjacencyList(edges) {
        const adjacency = new Map();
        edges.forEach((edge) => {
            if (!adjacency.has(edge.from)) adjacency.set(edge.from, []);
            if (!adjacency.has(edge.to)) adjacency.set(edge.to, []);

            adjacency.get(edge.from).push({
                to: edge.to,
                distance: Number(edge.distance || 0),
                time: Number(edge.time || 0),
                cost: Number(edge.cost || 0)
            });
            adjacency.get(edge.to).push({
                to: edge.from,
                distance: Number(edge.distance || 0),
                time: Number(edge.time || 0),
                cost: Number(edge.cost || 0)
            });
        });
        return adjacency;
    }

    function pathToKey(routePath) {
        return routePath.join('>');
    }

    function findAlternativePaths(source, destination, optimalPath, maxCount = 3) {
        const adjacency = buildAdjacencyList(allEdgesData);
        if (!adjacency.has(source) || !adjacency.has(destination)) return [];

        const preferenceField = activePreference === 'time'
            ? 'time'
            : activePreference === 'cost'
                ? 'cost'
                : 'distance';

        const optimalKey = pathToKey(optimalPath);
        const candidates = [];
        const maxDepth = Math.min(allCities.length, Math.max(optimalPath.length + 3, 6));
        const maxSearchStates = 12000;
        let searchStates = 0;

        function dfs(current, visited, currentPath, totals) {
            if (searchStates >= maxSearchStates) return;
            searchStates++;

            if (currentPath.length > maxDepth) return;
            if (current === destination) {
                const key = pathToKey(currentPath);
                if (key !== optimalKey) {
                    candidates.push({
                        path: [...currentPath],
                        distance: totals.distance,
                        time: totals.time,
                        cost: totals.cost
                    });
                }
                return;
            }

            const neighbors = adjacency.get(current) || [];
            for (let i = 0; i < neighbors.length; i++) {
                const neighbor = neighbors[i];
                if (visited.has(neighbor.to)) continue;

                visited.add(neighbor.to);
                currentPath.push(neighbor.to);
                dfs(
                    neighbor.to,
                    visited,
                    currentPath,
                    {
                        distance: totals.distance + neighbor.distance,
                        time: totals.time + neighbor.time,
                        cost: totals.cost + neighbor.cost
                    }
                );
                currentPath.pop();
                visited.delete(neighbor.to);
            }
        }

        const visited = new Set([source]);
        dfs(source, visited, [source], { distance: 0, time: 0, cost: 0 });

        const seen = new Set();
        const unique = [];
        candidates
            .sort((a, b) => {
                if (a[preferenceField] !== b[preferenceField]) return a[preferenceField] - b[preferenceField];
                if (a.path.length !== b.path.length) return a.path.length - b.path.length;
                return a.distance - b.distance;
            })
            .forEach((route) => {
                const key = pathToKey(route.path);
                if (!seen.has(key)) {
                    seen.add(key);
                    unique.push(route);
                }
            });

        return unique.slice(0, maxCount);
    }

    const alternativeRoutes = findAlternativePaths(sourceCity, destinationCity, path, 3);

    async function geocodeCitiesForMap(cities) {
        const uniqueCities = [...new Set((cities || []).filter(Boolean))];
        const missing = uniqueCities.filter((city) => !mapGeocodeCache.has(city));

        if (missing.length) {
            try {
                const response = await fetch('/api/geocode-batch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cities: missing })
                });
                if (!response.ok) throw new Error(`Geocoding service failed: HTTP ${response.status}`);

                const payload = await response.json();
                const coords = payload?.coords || {};
                Object.entries(coords).forEach(([city, point]) => {
                    if (Array.isArray(point) && point.length === 2) {
                        mapGeocodeCache.set(city, [Number(point[0]), Number(point[1])]);
                    }
                });
            } catch (_) {
                for (const city of missing) {
                    try {
                        const q = encodeURIComponent(`${city}, India`);
                        const r = await fetch(`https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=${q}`);
                        if (!r.ok) continue;
                        const data = await r.json();
                        if (Array.isArray(data) && data.length) {
                            mapGeocodeCache.set(city, [Number(data[0].lat), Number(data[0].lon)]);
                        }
                    } catch (_) {}
                }
            }
        }

        const cityToCoord = new Map();
        uniqueCities.forEach((city) => {
            if (mapGeocodeCache.has(city)) {
                cityToCoord.set(city, mapGeocodeCache.get(city));
            }
        });
        return cityToCoord;
    }

    function renderAlternativeRoutes(routes) {
        const otherRoutesList = document.getElementById('otherRoutesList');
        otherRoutesList.innerHTML = '';

        if (!routes.length) {
            otherRoutesList.innerHTML = '<p class="no-other-routes">No practical alternate paths found in the current graph.</p>';
            return;
        }

        routes.forEach((route, index) => {
            const item = document.createElement('div');
            item.className = 'other-route-item';
            const color = alternativePalette[index % alternativePalette.length];

            item.innerHTML = `
                <div class="other-route-head">
                    <span class="route-chip" style="background:${color};"></span>
                    <p>Alternative ${index + 1}</p>
                </div>
                <p class="other-route-path">${route.path.join(' → ')}</p>
                <p class="other-route-meta">${route.distance} km · ${route.time} min · ₹${route.cost}</p>
            `;
            otherRoutesList.appendChild(item);
        });
    }

    async function renderRouteMap(pathCities, alternatives, accentColor) {
        const fallbackEl = document.getElementById('mapFallback');
        const mapContainer = document.getElementById('route-map');

        if (!window.L) {
            fallbackEl.textContent = 'Map library could not load.';
            return;
        }
        if (!Array.isArray(pathCities) || pathCities.length < 2) {
            fallbackEl.textContent = 'Not enough points to render a map.';
            return;
        }

        try {
            const routePaths = [pathCities, ...alternatives.map((route) => route.path)];
            const allCitiesInRoutes = [...new Set(routePaths.flat())];
            const cityToCoord = await geocodeCitiesForMap(allCitiesInRoutes);

            const map = L.map(mapContainer, { zoomControl: true });
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 18,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const allCoordsForBounds = [];

            alternatives.forEach((route, index) => {
                const altCoords = route.path
                    .map((city) => cityToCoord.get(city))
                    .filter(Boolean);
                if (altCoords.length < 2) return;

                allCoordsForBounds.push(...altCoords);
                L.polyline(altCoords, {
                    color: alternativePalette[index % alternativePalette.length],
                    weight: 3,
                    opacity: 0.65,
                    dashArray: '8 6'
                }).addTo(map);
            });

            const optimalPoints = pathCities
                .map((city) => ({ city, coord: cityToCoord.get(city) }))
                .filter((item) => Array.isArray(item.coord));
            const optimalCoords = optimalPoints.map((item) => item.coord);

            if (optimalCoords.length < 2) {
                fallbackEl.textContent = 'Map unavailable: not enough geocoded points for this route.';
                return;
            }

            L.polyline(optimalCoords, {
                color: accentColor,
                weight: 5,
                opacity: 0.92
            }).addTo(map);

            optimalPoints.forEach((item, index) => {
                const marker = L.circleMarker(item.coord, {
                    radius: index === 0 || index === optimalCoords.length - 1 ? 7 : 5,
                    color: '#ffffff',
                    weight: 2,
                    fillColor: accentColor,
                    fillOpacity: 0.95
                }).addTo(map);

                marker.bindPopup(`<b>${item.city}</b><br>Stop ${index + 1}`);
            });

            map.fitBounds([...allCoordsForBounds, ...optimalCoords], { padding: [30, 30] });
            fallbackEl.textContent = '';
        } catch (e) {
            fallbackEl.textContent = `Map unavailable: ${e.message}`;
        }
    }

    document.getElementById('queryInfo').innerHTML =
        `<span>${query.source}</span> → <span>${query.destination}</span> &nbsp;|&nbsp; Preference: <span>${activePreference}</span>`;

    const dataSourceBadge = document.getElementById('dataSourceBadge');
    if (result.liveData) {
        dataSourceBadge.textContent = 'Live data enabled (OpenStreetMap + OSRM)';
        dataSourceBadge.classList.add('live');
    } else {
        dataSourceBadge.textContent = result.liveNote || 'Using base engine data (live unavailable)';
        dataSourceBadge.classList.add('fallback');
    }

    document.getElementById('totalDistance').innerText = `${totalDistance} km`;
    document.getElementById('totalTime').innerText = `${totalTime} mins`;
    document.getElementById('totalCost').innerText = `₹${totalCost}`;
    document.getElementById('stops').innerText = stops;

    const pathDisplay = document.getElementById('pathDisplay');
    path.forEach((city, i) => {
        const node = document.createElement('span');
        node.classList.add('path-node');
        node.innerText = city;
        pathDisplay.appendChild(node);

        if (i < path.length - 1) {
            const arrow = document.createElement('span');
            arrow.classList.add('path-arrow');
            arrow.innerText = ' → ';
            pathDisplay.appendChild(arrow);
        }
    });

    const routeStepper = document.getElementById('routeStepper');
    path.forEach((city, i) => {
        const step = document.createElement('div');
        step.className = 'step-item';

        const badge = document.createElement('div');
        badge.className = 'step-badge';
        badge.innerText = i + 1;

        const label = document.createElement('p');
        label.className = 'step-label';
        label.innerText = city;

        step.appendChild(badge);
        step.appendChild(label);
        routeStepper.appendChild(step);

        if (i < path.length - 1) {
            const connector = document.createElement('div');
            connector.className = 'step-connector';

            const leg = getLeg(path[i], path[i + 1]);
            connector.innerHTML = leg
                ? `<span>${leg.distance} km</span><span>${leg.time} min</span><span>₹${leg.cost}</span>`
                : '<span>Connected</span>';

            routeStepper.appendChild(connector);
        }
    });

    const legsGrid = document.getElementById('legsGrid');
    for (let i = 0; i < path.length - 1; i++) {
        const from = path[i];
        const to = path[i + 1];
        const leg = getLeg(from, to);

        const card = document.createElement('div');
        card.className = 'leg-card';

        card.innerHTML = `
            <p class="leg-route">${from} → ${to}</p>
            <p class="leg-meta">${leg ? `${leg.distance} km` : '-- km'} · ${leg ? `${leg.time} min` : '-- min'} · ${leg ? `₹${leg.cost}` : '₹--'}</p>
        `;

        legsGrid.appendChild(card);
    }

    renderAlternativeRoutes(alternativeRoutes);

    if (window.vis && window.vis.Network && allCities.length) {
        const nodes = new vis.DataSet(allCities.map(city => ({
            id: city,
            label: city,
            color: { background: '#1a1a2e', border: palette.accent },
            font: { color: '#ffffff' }
        })));

        const edges = new vis.DataSet(allEdgesData.map((edge, index) => ({
            id: index,
            from: edge.from,
            to: edge.to,
            title: `${edge.distance} km | ${edge.time} min | ₹${edge.cost}`,
            color: { color: '#444444' },
            width: 1.5
        })));

        const optimalEdgeKeys = new Set();
        const alternateEdgeKeys = new Set();

        for (let i = 0; i < path.length - 1; i++) {
            optimalEdgeKeys.add(edgeKey(path[i], path[i + 1]));
        }

        alternativeRoutes.forEach((route) => {
            for (let i = 0; i < route.path.length - 1; i++) {
                alternateEdgeKeys.add(edgeKey(route.path[i], route.path[i + 1]));
            }
        });

        path.forEach(city => {
            nodes.update({
                id: city,
                color: { background: palette.accent, border: '#ffffff' },
                font: { color: '#000000' }
            });
        });

        edges.forEach((edge) => {
            const key = edgeKey(edge.from, edge.to);
            if (optimalEdgeKeys.has(key)) {
                edges.update({ id: edge.id, color: { color: palette.highlight }, width: 4, dashes: false });
            } else if (alternateEdgeKeys.has(key)) {
                edges.update({ id: edge.id, color: { color: alternativeGraphColor }, width: 2.5, dashes: true });
            }
        });

        const container = document.getElementById('graph-container');
        new vis.Network(container, { nodes, edges }, {
            physics: { enabled: true },
            edges: { smooth: true },
            interaction: { hover: true }
        });
    } else {
        document.getElementById('graph-container').innerHTML =
            '<p class="graph-fallback">Graph view unavailable, but your path timeline is shown above.</p>';
    }

    renderRouteMap(path, alternativeRoutes, palette.highlight);
</script>
