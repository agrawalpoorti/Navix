NODE_ENV=production
PORT=8080
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/navix
JWT_SECRET=replace_with_a_long_random_secret
HTTP_TIMEOUT_MS=12000
HTTP_RETRY_COUNT=3
APP_USER_AGENT=Navix/1.0 (your_email@example.com)
CONTACT_EMAIL=your_email@example.com
# Optional: leave unset unless you need a custom absolute engine path.
# ENGINE_PATH=/absolute/path/to/DSA_LOGIC/navix_engine
# OSRM_BASE_URL=https://router.project-osrm.org
